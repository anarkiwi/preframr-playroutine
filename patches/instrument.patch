diff --git a/src/instrument.h b/src/instrument.h
new file mode 100644
index 0000000..3984ed4
--- /dev/null
+++ b/src/instrument.h
@@ -0,0 +1,91 @@
+/*
+ * This file is part of libsidplayfp, a SID player engine.
+ *
+ * Instrumentation hook (preframr-playroutine fork).
+ *
+ * Provides a process-wide sink that receives byte-exact, cycle-stamped
+ * SID register writes plus IRQ/NMI machine-timing events. The library
+ * calls these from the emulation core only when a sink is installed, so
+ * stock behaviour is unchanged when no sink is set.
+ *
+ * This program is free software; you can redistribute it and/or modify
+ * it under the terms of the GNU General Public License as published by
+ * the Free Software Foundation; either version 2 of the License, or
+ * (at your option) any later version.
+ */
+
+#ifndef LIBSIDPLAYFP_INSTRUMENT_H
+#define LIBSIDPLAYFP_INSTRUMENT_H
+
+#include <cstdint>
+
+#include "sidplayfp/siddefs.h"
+
+namespace libsidplayfp
+{
+
+/**
+ * Receives instrumentation events from the emulation core.
+ *
+ * All cycle values are absolute event-scheduler times expressed on the
+ * visible CPU clock (PHI2 for CPU/SID events, PHI1 for chip events); they
+ * share a single monotonic cycle axis.
+ */
+class InstrumentSink
+{
+public:
+    virtual ~InstrumentSink() {}
+
+    /// A write reaching a SID chip: register (0..0x1f) and value, with the
+    /// chip index and its base address (e.g. 0xd400), plus the store-site PC.
+    virtual void sidWrite(int64_t cycle, int chip, uint16_t base,
+                          uint8_t reg, uint8_t value, uint16_t pc) = 0;
+
+    /// A CIA interrupt line was asserted. source: 1=CIA1 (IRQ), 2=CIA2 (NMI).
+    /// taLatch/tbLatch are the current timer A/B reload latches (period in
+    /// cycles) at assertion time.
+    virtual void ciaIrq(int64_t cycle, int source,
+                        uint16_t taLatch, uint16_t tbLatch) = 0;
+
+    /// A VIC-II raster interrupt line was asserted. rasterY is the current
+    /// raster line, rasterCmp the programmed compare line.
+    virtual void vicIrq(int64_t cycle, unsigned rasterY, unsigned rasterCmp) = 0;
+
+    /// The CPU vectored through an interrupt/BRK. kind is the low byte of the
+    /// vector address: 0xfe=IRQ, 0xfa=NMI, 0xfc=RST. pc is the handler entry.
+    virtual void cpuVector(int64_t cycle, uint8_t kind, uint16_t pc) = 0;
+
+    /// A CPU write to memory inside a play window. pc is the storing
+    /// instruction, kind the window kind (0=IRQ, 1=NMI). Includes writes to the
+    /// player's code region (self-modifying code); the tracer filters address
+    /// ranges it does not care about.
+    virtual void ramWrite(int64_t cycle, uint16_t pc, uint16_t addr,
+                          uint8_t value, uint8_t kind) {}
+
+    /// A CPU operand data read inside a play window. Only emitted when
+    /// wantReads() returns true.
+    virtual void ramRead(int64_t cycle, uint16_t pc, uint16_t addr,
+                         uint8_t value, uint8_t kind) {}
+
+    /// An instruction executed inside a play window (for PC coverage).
+    virtual void cpuExec(uint16_t pc, uint8_t kind) {}
+
+    /// Whether the read log is wanted (gates the per-read overhead).
+    virtual bool wantReads() const { return false; }
+};
+
+/// Install (or clear, with nullptr) the process-wide instrumentation sink.
+SID_EXTERN void setInstrumentSink(InstrumentSink *sink);
+
+/// Get the currently installed sink, or nullptr.
+SID_EXTERN InstrumentSink *getInstrumentSink();
+
+/// Current CPU instruction PC, maintained by the CPU core so that SID writes
+/// (emitted from the SID emulation) can be attributed to their store site.
+/// Library-internal (not exported); only meaningful while a sink is installed.
+void setInstrumentCurrentPC(uint16_t pc);
+uint16_t getInstrumentCurrentPC();
+
+}
+
+#endif // LIBSIDPLAYFP_INSTRUMENT_H
